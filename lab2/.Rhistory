#lab1-7
# 使用 scan() 函数读取数据
# what 参数指定了每一行的数据结构：
# "" 代表字符型（对应动物名称），0 代表数值型（对应编号和数字）
animal_list <- scan("animal_data.txt", what = list(id = 0, name = "", value = 0), quiet = TRUE)
# 打印读取后的列表
print(animal_list)
#lab1-10
# 1. 定义向量 x
x <- c(1, 3, 5, 7, 9)
# 2. 构造矩阵 X
# cbind 会自动将向量按列合并
# R 语言具有向量化运算特性，x^2 会自动计算每个元素的平方
X <- cbind(const = 1, x = x, `x^2` = x^2)
# 3. 查看结果
print(X)
