#lab5-1
#录入体重数据
w <- c(75.0,64.0,47.4,66.9,62.2,62.2,58.7,63.5,66.6,64.0,57.0,69.0,56.9,50.0,72.0)
#(1)均值
mean_w <- mean(w)
cat("(1)平均体重：",mean_w,"\n")
#(2)方差、标准差（样本方差var，样本标准差sd）
var_w <- var(w)
sd_w <- sd(w)
cat("(2)样本方差：",var_w," 样本标准差：",sd_w,"\n")
#(3)升序排序
sort_w <- sort(w)
cat("(3)升序排序：\n",sort_w,"\n")
#(4)中位数
med_w <- median(w)
cat("(4)中位数：",med_w,"\n")
#(5)指定分位数：0,0.25,0.5,0.75,1
q_w <- quantile(w,probs = c(0,0.25,0.5,0.75,1))
cat("(5)各分位数：\n")
print(q_w)
# lab5-2 自编函数计算 偏度系数 & 峰度系数
# 1. 上一题体重数据
w <- c(75.0,64.0,47.4,66.9,62.2,62.2,58.7,63.5,66.6,64.0,57.0,69.0,56.9,50.0,72.0)
# 2. 自编函数：计算偏度系数
skewness <- function(x) {
n <- length(x)
x_bar <- mean(x)
m3 <- sum((x - x_bar)^3) / n
s <- sd(x)
g1 <- m3 / (s^3)
return(g1)
}
# 3. 自编函数：计算峰度系数
kurtosis <- function(x) {
n <- length(x)
x_bar <- mean(x)
m4 <- sum((x - x_bar)^4) / n
s <- sd(x)
g2 <- m4 / (s^4) - 3  # 减3是为了让正态分布峰度=0
return(g2)
}
# 4. 计算结果
g1 <- skewness(w)
g2 <- kurtosis(w)
# 5. 输出
cat("偏度系数 g1 =", g1, "\n")
cat("峰度系数 g2 =", g2, "\n")
# lab5-3 蒙特卡洛近似计算定积分
n <- 1000000   # 抽样点数，越大精度越高
x <- runif(n, min = 0, max = 1)  # [0,1]均匀随机数
fx <- exp(-x^2)
I_mc <- (1-0) * mean(fx)
cat("蒙特卡洛积分近似值 =",I_mc,"\n")
