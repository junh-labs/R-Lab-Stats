#练习1
# 定义θ
theta <- pi / 4
# (1) 3*sin(θ) + 2*cos(θ)
res1 <- 3 * sin(theta) + 2 * cos(theta)
cat("(1) 3sinθ + 2cosθ =", res1, "\n")
# (2) e^θ * sin(2θ) + e^(2θ) * sinθ
res2 <- exp(theta) * sin(2 * theta) + exp(2 * theta) * sin(theta)
cat("(2) e^θ sin2θ + e^(2θ) sinθ =", res2, "\n")
