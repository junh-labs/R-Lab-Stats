chengji(100)
chengji <- function(x){
if (x >= 90) {
print("优")
} else
if (x >= 80){
print("良")
} else
if (x >= 70){
print("中")
} else
if (x >= 60){
print("及格")
} else
print("不及格")
}
chengji(100)
