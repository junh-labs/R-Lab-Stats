# 任意步长等差数列 seq()
seq(1, 10)
seq(10)
seq(2, 10, by = 2)
seq(1, 10, by = 2)
seq(1, 10, length.out = 5)
seq(1, 10, along.with = c(1,3,5))
# 重复向量 rep()
x <- 1:4
rep(x, times = 2)
rep(x, length.out = 10)
rep(x, each = 2)
rep(x, c(1:4))
# 向量索引（R下标从1开始）
x <- 1:10
x[1]
x[1:3]
x[c(1,4,7)]
# 3. 删除与修改元素
x <- 1:10
x[-3]        # 删除第3个元素
x[-(1:4)]    # 删除前4个
x[-c(3,6,9)] # 删除指定位置
# 修改元素
x[3] <- 18
x
x[1:3] <- c(10,20,30)
x
x[c(3,6,9)] <- c(12,24,36)
x
