attach(tj)
data(cars);
plot(cars$speed, cars$dist, main = "速度与制动距离的回归分析",
pch = 19, xlab = "速度(mile/h)", ylab = "距离(ft)");
speed.reg <- lm(cars$dist ~ cars$speed, data = cars);
abline(speed.reg, lty = 2, col = 2, lwd = 2);
speed.p2 <- lm(cars$dist ~ cars$speed + I(cars$speed^2), data = cars)
#summary(speed.p2)
x = cars$speed;
y = 2.47014 + 0.91329 * x + 0.09996 * x * x;
points(x, y, lty = 4, col = 3, lwd = 2)
legend(4,100,legend = c("线性回归", "多项式回归"), lty = c(2,4), col = c("red", "green"))
data(VADeaths)
dotchart(VADeaths, main = 'Death Rates in Virginia - 1940')
# 1. 绘制散点图
plot(pressure$temperature, pressure$pressure,
xlab = "温度 (Temperature)",      # x轴标签
ylab = "压力 (Pressure)",         # y轴标签
main = "水蒸气温度与压力的关系",   # 标题
pch = 19,                        # 实心圆点
col = "blue",                    # 点的颜色
cex = 1.2)                       # 点的大小
# 添加网格线（可选，让图形更清晰）
grid(col = "gray", lty = 2)
# 可选：添加趋势线（Loess平滑曲线）
lines(lowess(pressure$temperature, pressure$pressure),
col = "red", lwd = 2)
# 添加图例说明
legend("topleft",
legend = c("观测数据", "趋势线"),
col = c("blue", "red"),
pch = c(19, NA),
lty = c(NA, 1),
lwd = c(NA, 2))
