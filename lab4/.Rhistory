# 二、算术操作
# ----------------------
# 基础运算
9 %% 4    # 求余
(1:10) %% 2
9 %/% 4   # 求商
(1:10) %/% 2
2 ^ 3     # 乘方
(1:10)^3
sqrt(9)   # 开方
sqrt(1:10)
sqrt(-9)  # 负数开方报错
# 对数与指数
log(16, 2)
log(c(2,4,8,16), base=2)
log2(16)
log10(100)
exp(1)
exp(1:3)
# 常用数学函数
abs(-5)
ceiling(3.2)
floor(3.8)
trunc(3.99)
round(3.1415, 2)
